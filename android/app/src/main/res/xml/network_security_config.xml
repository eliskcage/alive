<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- HTTPS only — no cleartext traffic -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Pin shortfactory.shop domain -->
    <domain-config>
        <domain includeSubdomains="true">shortfactory.shop</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
