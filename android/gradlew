#!/bin/sh
# Gradle wrapper — downloads gradle if not present, then runs it.
# This is a minimal wrapper. For a full one, use `gradle wrapper` command.

##############################################################################
#
#  Gradle start up script for POSIX generated by Gradle.
#
##############################################################################

APP_NAME="Gradle"
APP_BASE_NAME=$(basename "$0")
MAX_FD="maximum"
warn () { echo "$*"; }
die () { echo "$*"; exit 1; }

# Resolve links
PRG="$0"
while [ -h "$PRG" ] ; do
    ls=$(ls -ld "$PRG")
    link=$(expr "$ls" : '.*-> \(.*\)$')
    if expr "$link" : '/.*' > /dev/null; then PRG="$link"
    else PRG=$(dirname "$PRG")"/$link"; fi
done
SAVED="$(pwd)"
cd "$(dirname "$PRG")/" >/dev/null
APP_HOME="$(pwd -P)"
cd "$SAVED" >/dev/null

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Determine the Java command to use
if [ -n "$JAVA_HOME" ] ; then
    JAVACMD="$JAVA_HOME/bin/java"
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME"
    fi
else
    JAVACMD="java"
    which java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' in PATH."
fi

# Check for gradle wrapper jar
if [ ! -f "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" ]; then
    echo "Downloading Gradle wrapper..."
    mkdir -p "$APP_HOME/gradle/wrapper"
    WRAPPER_URL="https://services.gradle.org/distributions/gradle-8.5-bin.zip"
    if command -v curl >/dev/null 2>&1; then
        curl -sL "$WRAPPER_URL" -o /tmp/gradle.zip
    elif command -v wget >/dev/null 2>&1; then
        wget -q "$WRAPPER_URL" -O /tmp/gradle.zip
    else
        die "Neither curl nor wget found. Install Gradle manually."
    fi
    echo "Use 'gradle wrapper' to generate the proper wrapper, or install Android Studio."
    die "Gradle wrapper jar not found. Run 'gradle wrapper --gradle-version 8.5' in this directory first."
fi

exec "$JAVACMD" \
    $JAVA_OPTS \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"
